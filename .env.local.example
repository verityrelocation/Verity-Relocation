# Stripe — get these from https://dashboard.stripe.com/test/apikeys
# Use TEST keys for local development. Live keys go in Vercel only.

# Server-side secret key (NEVER commit, NEVER expose to browser)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Client-side publishable key (safe to expose, must be prefixed NEXT_PUBLIC_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Webhook signing secret — get from `stripe listen` CLI for local dev,
# or from Vercel webhook endpoint settings for production
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
